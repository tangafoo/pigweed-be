# Copy this file to `.env` and fill in real values for local dev.
# `.env` is gitignored; this file (`.env.example`) is committed as a
# checklist of what's required to run pigweed.
#
# On the deployed host (Railway) set these in the host's
# environment-variables panel, not in a committed file.

# ─── Database (Supabase) ───────────────────────────────────────────
# Pooler URL — runtime queries. Port 6543, add `?pgbouncer=true`.
DATABASE_URL=

# Direct URL — Prisma CLI (migrations, db push). Port 5432, no pooler flag.
DIRECT_URL=

# ─── Auth (Better Auth) ────────────────────────────────────────────
# Long random string. Generate with `openssl rand -base64 32`.
# MUST be different between dev and prod.
BETTER_AUTH_SECRET=

# Browser origin(s) of the frontend, comma-separated. Drives BOTH the
# CORS middleware and Better Auth's trustedOrigins (CSRF allow-list).
# Local: http://localhost:5173 (SvelteKit dev server)
# Prod:  https://ourlittlefarm.club
CORS_ORIGIN=http://localhost:5173

# Base URL the auth flow redirects back to. Used in callback URLs.
# This is the BACKEND's public URL — NOT the FE domain.
# Local: http://localhost:3000
# Prod:  whatever Railway assigns when the BE deploys (TBD).
BETTER_AUTH_URL=http://localhost:3000

# ─── Passkeys (WebAuthn) ───────────────────────────────────────────
# rpID is the DNS effective-domain passkeys bind to. MUST match the
# FE host EXACTLY (no scheme, no port). The browser refuses a passkey
# ceremony if the page's host doesn't match this. Once a passkey is
# created against an rpID, changing the rpID orphans it — pick the
# apex domain in prod (ourlittlefarm.club, not www.ourlittlefarm.club).
#   Local: localhost
#   Prod:  ourlittlefarm.club
PASSKEY_RP_ID=localhost

# Human-readable label shown in the browser/OS credential prompt:
# "Use a passkey for <PASSKEY_RP_NAME>?". Brand-y, free text.
PASSKEY_RP_NAME=ourlittlefarm

# Full origin (scheme + host + optional port) of the FE. NO trailing /.
#   Local: http://localhost:5173 (SvelteKit dev server)
#   Prod:  https://ourlittlefarm.club
PASSKEY_ORIGIN=http://localhost:5173

# ─── Stripe ────────────────────────────────────────────────────────
# Secret key. Dev uses sk_test_..., prod uses sk_live_...
STRIPE_SECRET_KEY=

# Webhook signing secret. Get from `stripe listen` locally, or from
# the Stripe Dashboard's webhook endpoint settings in prod.
STRIPE_WEBHOOK_SECRET=

# ─── AI Moderation ─────────────────────────────────────────────────
# OpenAI key for the Moderation API (omni-moderation-latest is free —
# no token cost). If unset, moderation FAILS OPEN: posts/comments are
# allowed and a warning is logged. Set this before any real launch.
OPENAI_API_KEY=

# ─── Environment ───────────────────────────────────────────────────
# Leave unset (or set to "development") locally.
# Set to "production" only on the deployed host. Activates prod-mode
# behavior across Hono, Prisma, Better Auth, AND pigweed's own
# refuseIfProd() safety checks.
NODE_ENV=
