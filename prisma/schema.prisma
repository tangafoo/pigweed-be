// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// IDENTITY — pigweed users are animals on a farm. Animal is
// assigned randomly at signup and rerollable via /me/avatar/reroll.
// avatarSeed feeds deterministic color/pattern math on the FE
// so two CHICKENs with different seeds look visually distinct.
// Username and gender are user-chosen at signup.
// ─────────────────────────────────────────────────────────────

enum Animal {
  CHICKEN
  DOG
  GOOSE

  @@map("animal")
}

enum Gender {
  MALE
  FEMALE
  NONBINARY
  UNDISCLOSED

  @@map("gender")
}

// Produce section a post belongs to — backs the /posts page sections.
// Nullable on Post: owner "farm update" posts and general chatter carry
// no category. Adding a value later is a migration (acceptable — the
// produce lineup changes rarely).
enum PostCategory {
  EGGS
  VEGGIES
  FRUITS
  ANIMALS

  @@map("post_category")
}

// ─────────────────────────────────────────────────────────────
// AUTH — managed by Better Auth. Do not rename fields without
// also updating better-auth config; the library maps to these.
// ─────────────────────────────────────────────────────────────

model User {
  id                 String                  @id
  name               String
  email              String
  emailVerified      Boolean                 @default(false)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  // Identity — animals on the pigweed farm. See CLAUDE.md.
  // `username` is the normalized (lowercased) form Better Auth's username
  // plugin uses for uniqueness + login lookup. `displayUsername` preserves
  // the original casing the user typed (e.g. "Obi-Wan") for UI rendering.
  // Plugin writes both on signup; the create() blows up if either is missing.
  username           String                  @unique
  displayUsername    String?
  gender             Gender
  animal             Animal
  avatarSeed         Int // feeds deterministic FE color/pattern math
  // ourlittlefarm owner flag — owners' posts get a Reddit-style "OP" badge
  // so visitors can tell owner updates (farm pics/news) from customer
  // reviews. Default false; flipped manually (Studio/SQL) for the handful
  // of real owners. Surfaced read-only on the embedded post/comment author.
  isFarmOwner        Boolean                 @default(false)
  // Founding-flock flair — early subscribers wear a badge (like the OP badge)
  // on their posts/comments. Toggled manually by an admin from the panel.
  // Mirrors isFarmOwner's wiring exactly (selected onto the embedded author).
  isFoundingFlock    Boolean                 @default(false)
  // Admin-panel access (the boss). Set via CLI/Studio; gates every /admin/*
  // route. Separate from isFarmOwner so the public OP badge and the internal
  // admin power never get coupled.
  isAdmin            Boolean                 @default(false)
  // Note: pigweed does NOT store user current geo. The FE knows where
  // the user is (browser geolocation API) and sends lat/lng on each
  // request that needs it (post creation, feed query). Privacy-cleaner;
  // also lets a user explicitly "browse" another location's feed.
  coinBalance        Int                     @default(0)
  // Separate "currency" from coinBalance: earned (not bought) by granting
  // awards — every 10 grants → +5 unlockCoins via a Postgres trigger.
  // Spent on unlocking the attributed granters list for a post/comment.
  // NOT fungible with coinBalance.
  unlockCoins        Int                     @default(0)
  // Opt-out switch for the end-of-day digest email (comment/reply/upvote
  // activity). Default on; the unsubscribe link in every digest flips it
  // false. Transactional mail (welcome, OTP) ignores this flag — only the
  // batched digest respects it. See src/jobs/send-digests.ts.
  emailDigest        Boolean                 @default(true)
  // Stripe customer handle, lazily created the first time the user starts a
  // coin purchase or egg subscription that needs one. Reused across both so a
  // user has exactly one Stripe customer. Nullable: most users never buy.
  stripeCustomerId   String?                 @unique
  sessions           Session[]
  accounts           Account[]
  purchases          CoinPurchase[]
  posts              Post[]
  comments           Comment[]
  postVotes          PostVote[]
  commentVotes       CommentVote[]
  postAwardsGiven    PostAward[]
  commentAwardsGiven CommentAward[]
  postUnlocks        PostGrantersUnlock[]
  commentUnlocks     CommentGrantersUnlock[]
  achievements       UserAchievement[]
  passkeys           Passkey[]
  notifications      Notification[]
  subscription       Subscription?
  subscriptionPayments SubscriptionPayment[]

  @@unique([email])
  @@map("user")
}

// ─────────────────────────────────────────────────────────────
// NOTIFICATIONS — durable, batched activity records that back the
// end-of-day digest email. The in-process event bus is LOSSY (and
// fans out per-instance), so anything that must survive until the
// nightly job runs lives in Postgres, not on the bus.
//
// One row per noteworthy thing that happened TO a user (recipient =
// userId): someone commented on their post, replied to their comment,
// or upvoted their post. The digest job aggregates all rows where
// emailedAt IS NULL per recipient, sends ONE email, and stamps
// emailedAt so they're never re-sent.
//
// actorId / postId / commentId are plain ids (no FK relations) on
// purpose: posts/comments can be soft-deleted and actors removed, and
// we don't want cascade churn here — the digest job best-effort joins
// them and silently drops anything that's since vanished.
// ─────────────────────────────────────────────────────────────

enum NotificationType {
  COMMENT_ON_POST // someone commented on the recipient's post
  REPLY // someone replied to the recipient's comment
  POST_UPVOTE // someone upvoted the recipient's post
  COMMENT_UPVOTE // someone upvoted the recipient's comment
}

model Notification {
  id        String           @id @default(cuid())
  // Recipient — the user this email will go to.
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  actorId   String? // who did it (commenter / replier / voter)
  postId    String? // the post involved, when relevant
  commentId String? // the comment involved (REPLY / COMMENT_ON_POST)
  createdAt DateTime         @default(now())
  // null = pending (not yet in a digest). Set to now() by the job after
  // the digest email is sent. The partial-ish index below keeps the
  // "find everyone with pending notifications" scan cheap.
  emailedAt DateTime?

  @@index([userId, emailedAt])
  @@index([emailedAt])
  @@map("notification")
}

// Better Auth's passkey plugin owns this table. Field shape MUST match the
// plugin's expected schema (see https://better-auth.com/docs/plugins/passkey):
// any drift and the plugin's own create()/update() calls will fail at runtime
// the same way the username plugin's `displayUsername` did. `aaguid` is the
// authenticator's model identifier (Apple/Yubico/etc.) — useful for "you
// signed in from Touch ID" UX later.
model Passkey {
  id           String    @id
  name         String?
  publicKey    String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialID String
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  createdAt    DateTime?
  aaguid       String?

  @@map("passkey")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ─────────────────────────────────────────────────────────────
// COINS — Stripe-backed currency. CoinPack is the catalog
// (mirrors Stripe Products/Prices). CoinPurchase is the ledger
// row for each money→coins transaction, with stripeEventId as
// the idempotency key for webhook delivery.
// ─────────────────────────────────────────────────────────────

model CoinPack {
  id            String         @id @default(cuid())
  name          String
  coins         Int
  priceCents    Int
  currency      String         @default("usd")
  stripePriceId String         @unique
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  purchases     CoinPurchase[]

  @@map("coin_pack")
}

model CoinPurchase {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  coinPackId      String
  coinPack        CoinPack  @relation(fields: [coinPackId], references: [id])
  stripeSessionId String    @unique
  stripeEventId   String?   @unique
  coinsGranted    Int
  amountCents     Int
  currency        String    @default("usd")
  status          String    @default("pending")
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  @@index([userId])
  @@map("coin_purchase")
}

// ─────────────────────────────────────────────────────────────
// EGG SUBSCRIPTIONS — a standing RM50/week order. Two billing
// modes coexist behind one model:
//   • STRIPE — the customer has a card on file; Stripe owns the
//     recurring charge and we react to its webhooks (invoice.*).
//   • MANUAL — onboarded-by-email customers (the "aunties") who
//     still pay cash/transfer. No Stripe subscription; a weekly
//     job nudges the farm owner (WhatsApp) + the customer (email)
//     until they add a card and convert to STRIPE.
//
// SubscriptionPlan is the catalog (mirrors Stripe Product/Price,
// like CoinPack). Subscription is one-per-user. SubscriptionPayment
// is the per-delivery ledger — one row = one paid week = one egg
// tray — and powers the "you've eaten N eggs" stats page.
// ─────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  PENDING // (phase 2) Stripe checkout started, not yet confirmed
  ACTIVE // currently receiving eggs (manually collected today)
  PAUSED // temporarily paused by the subscriber/admin ("pause anytime" perk)
  PAST_DUE // (phase 2) a Stripe invoice failed
  CANCELED

  @@map("subscription_status")
}

enum SubscriptionBillingMode {
  STRIPE // card on file, Stripe auto-charges weekly
  MANUAL // cash/transfer, farm owner collects; weekly nudge job

  @@map("subscription_billing_mode")
}

model SubscriptionPlan {
  id              String         @id @default(cuid())
  name            String
  // (phase 2) Stripe Price id. NULL today — subscriptions are manual; the
  // seed creates no Stripe price. Populated when Stripe billing is switched on.
  stripePriceId   String?        @unique
  priceCents      Int            // total per delivery; RM2/egg → eggs × 200
  currency        String         @default("myr")
  // Eggs in one delivery. Tiers: 120 / 60 / 30. Drives both the price
  // (eggs × RM2) and the fun "you've eaten N eggs" stats.
  eggsPerDelivery Int            @default(30)
  // Delivery cadence in weeks: 1 = weekly, 2 = bi-weekly (the 30-egg tier).
  // (phase 2) maps to Stripe's recurring interval_count on a weekly price.
  cadenceWeeks    Int            @default(1)
  // Display order on the subscribe page (lowest first).
  sortOrder       Int            @default(0)
  active          Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  subscriptions   Subscription[]
  benefits        PlanBenefit[]

  @@map("subscription_plan")
}

model Subscription {
  id                   String                  @id @default(cuid())
  userId               String                  @unique
  user                 User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId               String
  plan                 SubscriptionPlan        @relation(fields: [planId], references: [id])
  status               SubscriptionStatus      @default(PENDING)
  billingMode          SubscriptionBillingMode
  // Effective start of the subscription. Distinct from createdAt (the row's
  // insert time) so an admin can BACKFILL a customer who's been subscribed for
  // months — drives the "subscribing since" + egg-journey stats.
  startedAt            DateTime                @default(now())
  // Weekly delivery day, 0=Sun … 6=Sat (default 4 = Thursday). Admin-editable
  // ("request a different day"); the FE calendar marks these with an egg.
  deliveryDay          Int                     @default(4)
  // Set once Stripe owns the recurring charge (STRIPE mode); null for MANUAL.
  stripeSubscriptionId String?                 @unique
  // Synced from Stripe invoices/subscription events. Null for MANUAL.
  currentPeriodEnd     DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  canceledAt           DateTime?
  payments             SubscriptionPayment[]

  @@index([status])
  @@map("subscription")
}

// (phase 2) Per-delivery payment ledger — written by the Stripe invoice
// webhook when auto-billing is switched on. Dormant today (manual payments
// happen off-platform via WhatsApp/bank transfer); kept so phase 2 is purely
// additive. One row = one paid delivery.
model SubscriptionPayment {
  id                String                  @id @default(cuid())
  subscriptionId    String
  subscription      Subscription            @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  userId            String
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Webhook idempotency key (Stripe event id). Null for MANUAL deliveries.
  stripeEventId     String?                 @unique
  stripeInvoiceId   String?
  amountCents       Int
  currency          String                  @default("myr")
  mode              SubscriptionBillingMode
  paidAt            DateTime                @default(now())

  @@index([userId])
  @@index([subscriptionId])
  @@map("subscription_payment")
}

// ─────────────────────────────────────────────────────────────
// SUBSCRIPTION BENEFITS — the editable perk list shown on the
// subscribe page (guaranteed eggs, priority allocation, durian
// first-access, …). Global (not tier-scoped) for now: every
// subscriber gets the same package. Managed by the admin panel
// (CRUD via /admin/benefits) rather than seed-only, since the boss
// will reword/reorder these over time. This is the seed of the CRM.
// ─────────────────────────────────────────────────────────────

model SubscriptionBenefit {
  id        String        @id @default(cuid())
  label     String
  sortOrder Int           @default(0)
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  plans     PlanBenefit[]

  @@map("subscription_benefit")
}

// Per-tier benefit checklist: a row here means "this tier includes this
// benefit". Many-to-many between SubscriptionPlan and SubscriptionBenefit so
// a perk's text lives once in the catalog and each tier just checks it on/off.
// The admin panel renders the full catalog as checkboxes per tier; PUT
// /admin/plans/:id/benefits replaces a tier's checked set.
model PlanBenefit {
  planId    String
  plan      SubscriptionPlan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  benefitId String
  benefit   SubscriptionBenefit @relation(fields: [benefitId], references: [id], onDelete: Cascade)

  @@id([planId, benefitId])
  @@index([benefitId])
  @@map("plan_benefit")
}

// ─────────────────────────────────────────────────────────────
// CONTENT — Posts are the canvas. Comments and Awards (later)
// attach to a Post. Soft-deleted via deletedAt so dependent
// rows keep their FK target intact when a post is "removed".
// All queries must filter `deletedAt: null` to hide them.
// ─────────────────────────────────────────────────────────────

model Post {
  id            String                                 @id @default(cuid())
  authorId      String
  author        User                                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title         String
  body          String
  // Frozen at creation — the post belongs to a place. Not nullable
  // because pigweed's whole model is location-bounded; a post without
  // geo can't be filtered into anyone's feed.
  latitude      Float
  longitude     Float
  // Coarse human place label (town/city), reverse-geocoded ONCE at
  // creation and frozen here — reads never hit a geocoder. Nullable: the
  // lookup fails open (null) and old rows predate the column. Deliberately
  // coarse (no street) for poster privacy. See utils/geo.ts:reverseGeocode.
  locationName  String?
  createdAt     DateTime                               @default(now())
  updatedAt     DateTime                               @updatedAt
  deletedAt     DateTime?
  upvoteCount   Int                                    @default(0)
  downvoteCount Int                                    @default(0)
  // false = OpenAI was unreachable at post time, content slipped through
  // unjudged (fail-open). The FE renders these with an UNMODERATED badge —
  // rare-by-nature collectibles, can't be farmed. true = OpenAI judged it.
  moderated     Boolean                                @default(true)
  // Produce section (eggs/veggies/fruits) or null for uncategorized
  // owner updates / chatter. Indexed for the /posts section filters.
  category      PostCategory?
  // Customer review rating 1–5, or null when the post isn't a review.
  // App-validated to 1..5 (no DB check constraint — kept simple).
  rating        Int?
  // PostGIS generated column. Postgres maintains it automatically from
  // latitude/longitude — every insert/update recomputes it, no app code.
  // Prisma can't express `GENERATED ALWAYS AS`, so:
  //  - Unsupported(...)        → Prisma won't model the type
  //  - @default(dbgenerated()) → "the DB owns this value", stops Prisma
  //                              emitting `ALTER COLUMN geo DROP DEFAULT`
  // The init migration's geo line is hand-written ONCE as GENERATED
  // (Prisma scaffolds it as a plain column; we replace that one line).
  // Never read/written via Prisma client — $queryRaw + ST_DWithin only.
  geo           Unsupported("geography(Point, 4326)")? @default(dbgenerated())
  media         PostMedia[]
  comments      Comment[]
  votes         PostVote[]
  awards        PostAward[]
  unlocks       PostGrantersUnlock[]

  @@index([authorId])
  @@index([createdAt])
  @@index([category])
  // Prisma-managed GIST index — declared here so Prisma creates it AND
  // never tries to drop it (this was a big source of the earlier pain).
  @@index([geo], type: Gist)
  @@map("post")
}

// PostMedia is a 1-to-many child of Post. `kind` is a plain string
// ("image", "video", "gif") not a Prisma enum — enums need a migration
// to add values, strings + app-side validation evolve more freely.
// Width/height are stored so clients can reserve layout space before
// the asset loads (prevents jank). onDelete: Cascade so media rows
// disappear when a post is hard-deleted.
model PostMedia {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  url       String
  kind      String
  order     Int      @default(0)
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  @@index([postId])
  @@map("post_media")
}

// Comment is self-referential: parentCommentId points back to id,
// forming a tree. We store `depth` so we can cheaply enforce a max
// nesting cap (single SELECT on the parent — no recursive walk).
// Soft-deleted: replies and future awards keep their FK intact.
// The named relation "CommentReplies" is required by Prisma because
// the model has two relations to the same model (parent + replies).
model Comment {
  id              String                  @id @default(cuid())
  postId          String
  post            Post                    @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId        String
  author          User                    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentCommentId String?
  parentComment   Comment?                @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies         Comment[]               @relation("CommentReplies")
  depth           Int                     @default(0)
  body            String
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  deletedAt       DateTime?
  upvoteCount     Int                     @default(0)
  downvoteCount   Int                     @default(0)
  // See Post.moderated — same semantics. false = slipped through unjudged.
  moderated       Boolean                 @default(true)
  votes           CommentVote[]
  awards          CommentAward[]
  unlocks         CommentGrantersUnlock[]

  @@index([postId])
  @@index([authorId])
  @@index([parentCommentId])
  @@index([postId, createdAt])
  @@map("comment")
}

// ─────────────────────────────────────────────────────────────
// VOTES — one row per (user, target). value is a closed enum
// (UP, DOWN) enforced at the DB level. Composite PK enforces
// one-vote-per-user without an extra `id` column. Aggregate
// counts on Post/Comment are kept in sync via $transaction at
// every vote write.
//
// Enum chosen here (despite the project's general "ints/strings
// + app validation" preference) because the value space is
// genuinely closed forever — there is no third vote direction.
// ─────────────────────────────────────────────────────────────

enum VoteValue {
  UP
  DOWN

  @@map("vote_value")
}

model PostVote {
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  value     VoteValue
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@id([userId, postId])
  @@index([postId])
  @@index([userId, value])
  @@map("post_vote")
}

model CommentVote {
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   Comment   @relation(fields: [commentId], references: [id], onDelete: Cascade)
  value     VoteValue
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@id([userId, commentId])
  @@index([commentId])
  @@index([userId, value])
  @@map("comment_vote")
}

// ─────────────────────────────────────────────────────────────
// AWARDS — pigweed's punk-communist economy: users spend coins
// (purchased or earned-via-achievement) to grant awards to other
// users' posts/comments. AwardType is the catalog (admin-seeded,
// like CoinPack), Post/CommentAward are the grants themselves.
//
// Multi-grant by design: one user can grant the same award type
// to the same post multiple times. Anonymous by default in the
// API (response summaries aggregate by award type only), but
// granterId IS stored — a separate granters endpoint surfaces
// it, eventually gated behind a pay-to-unlock (phase 2).
//
// coinsSpent is a SNAPSHOT of the price at grant time, so if an
// AwardType's priceCoins changes later, historical grants still
// reflect what was actually paid.
// ─────────────────────────────────────────────────────────────

model AwardType {
  id            String         @id @default(cuid())
  assetKey      String         @unique
  name          String
  priceCoins    Int
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  postAwards    PostAward[]
  commentAwards CommentAward[]

  @@map("award_type")
}

model PostAward {
  id          String    @id @default(cuid())
  granterId   String
  granter     User      @relation(fields: [granterId], references: [id], onDelete: Cascade)
  postId      String
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  awardTypeId String
  awardType   AwardType @relation(fields: [awardTypeId], references: [id])
  coinsSpent  Int
  createdAt   DateTime  @default(now())

  @@index([postId])
  @@index([granterId])
  @@index([postId, awardTypeId])
  @@map("post_award")
}

model CommentAward {
  id          String    @id @default(cuid())
  granterId   String
  granter     User      @relation(fields: [granterId], references: [id], onDelete: Cascade)
  commentId   String
  comment     Comment   @relation(fields: [commentId], references: [id], onDelete: Cascade)
  awardTypeId String
  awardType   AwardType @relation(fields: [awardTypeId], references: [id])
  coinsSpent  Int
  createdAt   DateTime  @default(now())

  @@index([commentId])
  @@index([granterId])
  @@index([commentId, awardTypeId])
  @@map("comment_award")
}

// ─────────────────────────────────────────────────────────────
// GRANTERS UNLOCKS — viewer X has unlocked the attributed
// granter list for post/comment Y, forever. unlockCoins earned
// by being generous (every 10 awards granted → +5 on User,
// applied via a Postgres trigger), spent here. Composite PK
// guarantees one row per (viewer, target).
// ─────────────────────────────────────────────────────────────

model PostGrantersUnlock {
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId     String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  unlockedAt DateTime @default(now())

  @@id([userId, postId])
  @@index([postId])
  @@map("post_granters_unlock")
}

model CommentGrantersUnlock {
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId  String
  comment    Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  unlockedAt DateTime @default(now())

  @@id([userId, commentId])
  @@index([commentId])
  @@map("comment_granters_unlock")
}

// ─────────────────────────────────────────────────────────────
// ACHIEVEMENTS — admin-seeded catalog + per-user grant ledger.
// Granted once per user (composite PK), triggers via in-process
// event bus (see src/events/bus.ts + src/utils/achievements.ts).
// Each grant atomically credits rewardCoins to User.coinBalance.
//
// DB-driven catalog: each Achievement row declares which metric
// to read (POSTS_CREATED, AWARDS_GRANTED, etc.) and the
// threshold to clear. Adding a new achievement = INSERT a row.
// Adding a new METRIC = enum migration + one new case in the
// metric → COUNT mapper (src/utils/achievements.ts).
// ─────────────────────────────────────────────────────────────

enum AchievementMetric {
  POSTS_CREATED
  REVIEWS_CREATED // posts that carry a star rating (a "review")
  COMMENTS_CREATED
  AWARDS_GRANTED
  // Never auto-evaluated (evaluateMetric returns 0): awarded only by an
  // explicit grant. Backs the admin-toggled "Founding Flock" badge.
  MANUAL

  @@map("achievement_metric")
}

model Achievement {
  id          String            @id @default(cuid())
  key         String            @unique
  name        String
  description String
  metric      AchievementMetric
  threshold   Int
  rewardCoins Int
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  grants      UserAchievement[]

  @@index([metric, active])
  @@map("achievement")
}

model UserAchievement {
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  rewardCoins   Int
  grantedAt     DateTime    @default(now())

  @@id([userId, achievementId])
  @@index([userId])
  @@map("user_achievement")
}
