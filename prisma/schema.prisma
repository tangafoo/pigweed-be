// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// AUTH — managed by Better Auth. Do not rename fields without
// also updating better-auth config; the library maps to these.
// ─────────────────────────────────────────────────────────────

model User {
  id            String         @id
  name          String
  email         String
  emailVerified Boolean        @default(false)
  image         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  coinBalance   Int            @default(0)
  sessions      Session[]
  accounts      Account[]
  purchases     CoinPurchase[]
  posts         Post[]
  comments      Comment[]
  postVotes     PostVote[]
  commentVotes  CommentVote[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ─────────────────────────────────────────────────────────────
// COINS — Stripe-backed currency. CoinPack is the catalog
// (mirrors Stripe Products/Prices). CoinPurchase is the ledger
// row for each money→coins transaction, with stripeEventId as
// the idempotency key for webhook delivery.
// ─────────────────────────────────────────────────────────────

model CoinPack {
  id            String         @id @default(cuid())
  name          String
  coins         Int
  priceCents    Int
  currency      String         @default("usd")
  stripePriceId String         @unique
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  purchases     CoinPurchase[]

  @@map("coin_pack")
}

model CoinPurchase {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  coinPackId      String
  coinPack        CoinPack  @relation(fields: [coinPackId], references: [id])
  stripeSessionId String    @unique
  stripeEventId   String?   @unique
  coinsGranted    Int
  amountCents     Int
  currency        String    @default("usd")
  status          String    @default("pending")
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  @@index([userId])
  @@map("coin_purchase")
}

// ─────────────────────────────────────────────────────────────
// CONTENT — Posts are the canvas. Comments and Awards (later)
// attach to a Post. Soft-deleted via deletedAt so dependent
// rows keep their FK target intact when a post is "removed".
// All queries must filter `deletedAt: null` to hide them.
// ─────────────────────────────────────────────────────────────

model Post {
  id            String      @id @default(cuid())
  authorId      String
  author        User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title         String
  body          String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  upvoteCount   Int         @default(0)
  downvoteCount Int         @default(0)
  media         PostMedia[]
  comments      Comment[]
  votes         PostVote[]

  @@index([authorId])
  @@index([createdAt])
  @@map("post")
}

// PostMedia is a 1-to-many child of Post. `kind` is a plain string
// ("image", "video", "gif") not a Prisma enum — enums need a migration
// to add values, strings + app-side validation evolve more freely.
// Width/height are stored so clients can reserve layout space before
// the asset loads (prevents jank). onDelete: Cascade so media rows
// disappear when a post is hard-deleted.
model PostMedia {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  url       String
  kind      String
  order     Int      @default(0)
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  @@index([postId])
  @@map("post_media")
}

// Comment is self-referential: parentCommentId points back to id,
// forming a tree. We store `depth` so we can cheaply enforce a max
// nesting cap (single SELECT on the parent — no recursive walk).
// Soft-deleted: replies and future awards keep their FK intact.
// The named relation "CommentReplies" is required by Prisma because
// the model has two relations to the same model (parent + replies).
model Comment {
  id              String        @id @default(cuid())
  postId          String
  post            Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId        String
  author          User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentCommentId String?
  parentComment   Comment?      @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies         Comment[]     @relation("CommentReplies")
  depth           Int           @default(0)
  body            String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?
  upvoteCount     Int           @default(0)
  downvoteCount   Int           @default(0)
  votes           CommentVote[]

  @@index([postId])
  @@index([authorId])
  @@index([parentCommentId])
  @@index([postId, createdAt])
  @@map("comment")
}

// ─────────────────────────────────────────────────────────────
// VOTES — one row per (user, target). value is a closed enum
// (UP, DOWN) enforced at the DB level. Composite PK enforces
// one-vote-per-user without an extra `id` column. Aggregate
// counts on Post/Comment are kept in sync via $transaction at
// every vote write.
//
// Enum chosen here (despite the project's general "ints/strings
// + app validation" preference) because the value space is
// genuinely closed forever — there is no third vote direction.
// ─────────────────────────────────────────────────────────────

enum VoteValue {
  UP
  DOWN

  @@map("vote_value")
}

model PostVote {
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  value     VoteValue
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@id([userId, postId])
  @@index([postId])
  @@index([userId, value])
  @@map("post_vote")
}

model CommentVote {
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   Comment   @relation(fields: [commentId], references: [id], onDelete: Cascade)
  value     VoteValue
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@id([userId, commentId])
  @@index([commentId])
  @@index([userId, value])
  @@map("comment_vote")
}
