{
  "name": "pigweed-be",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "seed": "bun scripts/seed-coin-packs.ts",
    "db:push": "bunx prisma db push",
    "db:reset": "bunx prisma db push --force-reset",
    "db:studio": "bunx prisma studio",
    "stripe:listen": "stripe listen --forward-to localhost:3000/stripe/webhook",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.6.10",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.10",
    "hono": "^4.12.18",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "prisma": "^7.8.0"
  }
}