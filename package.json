{
  "name": "pigweed-be",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "postinstall": "prisma generate",
    "seed": "bun scripts/seed-coin-packs.ts",
    "seed:awards": "bun scripts/seed-award-types.ts",
    "seed:achievements": "bun scripts/seed-achievements.ts",
    "seed:all": "bun scripts/seed-coin-packs.ts && bun scripts/seed-award-types.ts && bun scripts/seed-achievements.ts",
    "db:push": "bunx prisma db push",
    "db:reset": "bunx prisma migrate reset --force",
    "db:migrate": "bunx prisma migrate dev",
    "db:migrate-deploy": "bun scripts/db-migrate-deploy.ts",
    "db:count": "bun scripts/db-admin.ts count",
    "delete:user": "bun scripts/delete-user.ts",
    "db:studio": "bunx prisma studio",
    "stripe:listen": "stripe listen --forward-to localhost:3000/stripe/webhook",
    "jobs:digest": "bun src/jobs/send-digests.ts",
    "backfill:achievements": "bun scripts/backfill-achievements.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@better-auth/passkey": "1.6.11",
    "@better-auth/prisma-adapter": "^1.6.10",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.10",
    "heic-convert": "^2.1.0",
    "hono": "^4.12.18",
    "ioredis": "^5.11.1",
    "stripe": "^22.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "prisma": "^7.8.0"
  }
}